   "link": null,
   "locked": false,
   "text": "Externalized, optimizable surface of the agent:\n  base_system_prompt\n  tool_descriptions (per tool)\n  node_prompts\n\noptimizable: whitelist \u2014 optimizer refuses other keys\n\nHARNESS_CONFIG_PATH env override (call-time):\ncandidate configs evaluated without touching the\nreal file; always restored via try/finally",
   "fontSize": 12.5,
   "fontFamily": 3,
   "textAlign": "left",
   "verticalAlign": "top",
   "baseline": 14,
   "containerId": null,
   "originalText": "Externalized, optimizable surface of the agent:\n  base_system_prompt\n  tool_descriptions (per tool)\n  node_prompts\n\noptimizable: whitelist \u2014 optimizer refuses other keys\n\nHARNESS_CONFIG_PATH env override (call-time):\ncandidate configs evaluated without touching the\nreal file; always restored via try/finally",
   "lineHeight": 1.25
  },
